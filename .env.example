# AI Companion Robot realtime-first configuration

AI_COMPANION_AUTO_RUN=false
AI_COMPANION_INTERACTIVE_CONSOLE=false
AI_COMPANION_INPUT_MODE=speech
AI_COMPANION_INTERACTION_BACKEND=openai_realtime
AI_COMPANION_DEFAULT_LANGUAGE=en

AI_COMPANION_DATA_DIR=data
AI_COMPANION_MODELS_DIR=models
AI_COMPANION_LOGS_DIR=logs

# OpenAI Realtime speech-to-speech backend.
AI_COMPANION_CLOUD_ENABLED=false
AI_COMPANION_CLOUD_PROVIDER_NAME=openai
AI_COMPANION_USE_MOCK_AI=true
AI_COMPANION_OPENAI_API_KEY=
AI_COMPANION_OPENAI_REALTIME_MODEL=gpt-realtime-1.5
AI_COMPANION_OPENAI_REALTIME_VOICE=echo
AI_COMPANION_OPENAI_REALTIME_TURN_DETECTION=semantic_vad
AI_COMPANION_OPENAI_REALTIME_TURN_EAGERNESS=auto
AI_COMPANION_OPENAI_REALTIME_LOCAL_BARGE_IN_ENABLED=false
AI_COMPANION_OPENAI_REALTIME_INTERRUPT_RESPONSE=false
AI_COMPANION_OPENAI_REALTIME_PLAYBACK_BARGE_IN_ENABLED=true
AI_COMPANION_OPENAI_REALTIME_PLAYBACK_BARGE_IN_THRESHOLD=1800
AI_COMPANION_OPENAI_REALTIME_PLAYBACK_BARGE_IN_REQUIRED_MS=160
AI_COMPANION_OPENAI_REALTIME_PLAYBACK_BARGE_IN_GRACE_MS=450
AI_COMPANION_OPENAI_REALTIME_PLAYBACK_BARGE_IN_RECENT_VAD_MS=1800
AI_COMPANION_OPENAI_REALTIME_PLAYBACK_BARGE_IN_RECENT_REQUIRED_MS=40
AI_COMPANION_OPENAI_REALTIME_BASE_URL=wss://api.openai.com/v1/realtime
AI_COMPANION_OPENAI_REALTIME_AUDIO_SAMPLE_RATE=24000

# Microphone input. The runtime substitutes {output_path} with "-" and reads raw PCM.
# AI_COMPANION_AUDIO_RECORD_COMMAND=rec -q -c 1 -r 16000 -b 16 -e signed-integer -t raw {output_path}
# AI_COMPANION_AUDIO_RECORD_COMMAND=arecord -D plughw:2,0 -f S16_LE -r 16000 -c 6 -t raw {output_path}
AI_COMPANION_AUDIO_INIT_COMMAND=
AI_COMPANION_AUDIO_RECORD_COMMAND=
AI_COMPANION_AUDIO_INPUT_CHANNELS=1
AI_COMPANION_AUDIO_CHANNEL_INDEX=0

# Realtime audio output. macOS defaults to afplay when no command is configured.
# AI_COMPANION_AUDIO_PLAY_COMMAND=afplay {input_path}
# AI_COMPANION_AUDIO_PLAY_COMMAND=aplay {input_path}
AI_COMPANION_AUDIO_OUTPUT_BACKEND=command
AI_COMPANION_AUDIO_PLAY_COMMAND=
AI_COMPANION_AUDIO_ALSA_DEVICE=default
AI_COMPANION_AUDIO_ALSA_SAMPLE_RATE=24000
AI_COMPANION_AUDIO_ALSA_PERIOD_FRAMES=512
AI_COMPANION_AUDIO_ALSA_BUFFER_FRAMES=2048
AI_COMPANION_AUDIO_ALSA_KEEPALIVE_INTERVAL_MS=20
AI_COMPANION_AUDIO_SAVE_SESSION_RECORDING=false
AI_COMPANION_AUDIO_SESSION_RECORDING_DIR=data/audio/session-recordings

# Wake-word gate for realtime sessions.
AI_COMPANION_WAKE_WORD_ENABLED=false
AI_COMPANION_WAKE_WORD_PHRASE=Hey Jarvis
AI_COMPANION_WAKE_WORD_MODEL=hey jarvis
AI_COMPANION_WAKE_WORD_THRESHOLD=0.5
AI_COMPANION_WAKE_LOOKBACK_SECONDS=0.5
AI_COMPANION_FOLLOW_UP_MODE_ENABLED=true
AI_COMPANION_FOLLOW_UP_LISTEN_TIMEOUT_SECONDS=5.0
AI_COMPANION_INITIAL_SPEECH_TIMEOUT_SECONDS=5.0
AI_COMPANION_FOLLOW_UP_MAX_TURNS=10

# UI / face renderer.
AI_COMPANION_UI_BACKEND=mock
AI_COMPANION_UI_IDLE_SLEEP_SECONDS=300
AI_COMPANION_UI_SLEEPING_EYES_GRACE_SECONDS=12
AI_COMPANION_UI_SHOW_TEXT_OVERLAY=true
AI_COMPANION_UI_SLEEP_COMMAND=
AI_COMPANION_UI_WAKE_COMMAND=
AI_COMPANION_UI_BROWSER_HOST=127.0.0.1
AI_COMPANION_UI_BROWSER_HTTP_PORT=8765
AI_COMPANION_UI_BROWSER_WS_PORT=8766
AI_COMPANION_UI_BROWSER_LAUNCH_MODE=windowed
AI_COMPANION_UI_BROWSER_EXECUTABLE=
AI_COMPANION_UI_BROWSER_PROFILE_DIR=
AI_COMPANION_UI_BROWSER_EXTRA_ARGS=
AI_COMPANION_UI_BROWSER_STATE_PATH=
AI_COMPANION_UI_FACE_IDLE_ENABLED=true
AI_COMPANION_UI_FACE_IDLE_FREQUENCY=0.26
AI_COMPANION_UI_FACE_IDLE_INTENSITY=0.63
AI_COMPANION_UI_FACE_IDLE_PAUSE_RANDOMNESS=0.54
AI_COMPANION_UI_FACE_SECONDARY_MICRO_MOTION=true
AI_COMPANION_UI_FACE_IDLE_BEHAVIORS=blink||look_side||quick_glance||bored||curious||scoot||boundary_press

# Mock data for local development.
AI_COMPANION_USE_MOCK_VISION=true
AI_COMPANION_USE_MOCK_HARDWARE=true
AI_COMPANION_MOCK_ACTIVE_USER_ID=builder
AI_COMPANION_MOCK_ACTIVE_USER_NAME=Builder
AI_COMPANION_MOCK_ACTIVE_USER_SUMMARY=You are the robot's builder.
AI_COMPANION_MOCK_VISIBLE_PEOPLE=Builder

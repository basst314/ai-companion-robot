# Copy to .env.local or run scripts/setup.sh to generate a local config.
# The audio command intentionally uses placeholders expanded at runtime:
# {output_path} is replaced with "-" so the recorder writes raw PCM to stdout.

AI_COMPANION_INPUT_MODE=manual
AI_COMPANION_INTERACTIVE_CONSOLE=true
AI_COMPANION_STT_BACKEND=mock
AI_COMPANION_USE_MOCK_AI=true
AI_COMPANION_CLOUD_ENABLED=false
AI_COMPANION_CLOUD_PROVIDER_NAME=openai
# Leave blank if you want to enable OpenAI later and paste the key afterwards.
AI_COMPANION_OPENAI_API_KEY=
AI_COMPANION_OPENAI_BASE_URL=https://api.openai.com/v1/responses
# Default OpenAI model for cloud replies and tool-aware follow-ups.
AI_COMPANION_OPENAI_RESPONSE_MODEL=gpt-5.2
AI_COMPANION_OPENAI_TIMEOUT_SECONDS=20
# Hard ceiling for spoken cloud replies so the robot stays concise.
AI_COMPANION_OPENAI_REPLY_MAX_OUTPUT_TOKENS=120
AI_COMPANION_WHISPER_BINARY_PATH=
AI_COMPANION_WHISPER_MODEL_PATH=
# Example macOS command with sox/rec:
# AI_COMPANION_AUDIO_RECORD_COMMAND=rec -q -c 1 -r 16000 -b 16 -e signed-integer -t raw {output_path}
AI_COMPANION_AUDIO_RECORD_COMMAND=
AI_COMPANION_SPEECH_LATENCY_PROFILE=fast
AI_COMPANION_SPEECH_SILENCE_SECONDS=0.55
AI_COMPANION_VAD_THRESHOLD=0.45
AI_COMPANION_VAD_FRAME_MS=30
AI_COMPANION_VAD_START_TRIGGER_FRAMES=2
AI_COMPANION_VAD_END_TRIGGER_FRAMES=4
AI_COMPANION_MAX_RECORDING_SECONDS=15
AI_COMPANION_WAKE_WORD_ENABLED=false
# Built-in starter pairing for setup-generated configs:
# AI_COMPANION_WAKE_WORD_PHRASE=Hey Jarvis
# AI_COMPANION_WAKE_WORD_MODEL=hey jarvis
AI_COMPANION_WAKE_WORD_PHRASE=Hey Jarvis
AI_COMPANION_WAKE_WORD_MODEL=hey jarvis
AI_COMPANION_WAKE_WORD_THRESHOLD=0.5
AI_COMPANION_WAKE_LOOKBACK_SECONDS=0.5
AI_COMPANION_UTTERANCE_FINALIZE_TIMEOUT_SECONDS=0.25
AI_COMPANION_UTTERANCE_TAIL_STABLE_POLLS=1
AI_COMPANION_LANGUAGE_MODE=auto

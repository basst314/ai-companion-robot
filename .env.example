# Copy to .env.local or run scripts/setup.sh to generate a local config.
# The audio command intentionally uses placeholders expanded at runtime:
# {duration_seconds} and {output_path}

AI_COMPANION_INPUT_MODE=manual
AI_COMPANION_INTERACTIVE_CONSOLE=true
AI_COMPANION_STT_BACKEND=mock
AI_COMPANION_WHISPER_BINARY_PATH=
AI_COMPANION_WHISPER_MODEL_PATH=
AI_COMPANION_AUDIO_RECORD_COMMAND=
AI_COMPANION_RECORD_SECONDS=5
AI_COMPANION_LANGUAGE_MODE=auto
